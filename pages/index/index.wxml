<view class="container">
  <!-- Date navigation -->
  <view class="date-nav">
    <view class="date-btn prev" bindtap="onPrevDay">
      <text>{{'<'}}</text>
    </view>
    <view class="date-display">{{displayDate}}</view>
    <view class="date-btn next" bindtap="onNextDay">
      <text>{{'>'}}</text>
    </view>
  </view>

  <!-- View toggle -->
  <view class="view-toggle">
    <view class="toggle-btn {{viewMode === 'day' ? 'active' : ''}}" bindtap="switchToDayView">日视图</view>
    <view class="toggle-btn {{viewMode === 'week' ? 'active' : ''}}" bindtap="switchToWeekView">周视图</view>
  </view>

  <!-- Day view -->
  <view class="items-list" wx:if="{{viewMode === 'day'}}">
    <view
      class="item"
      wx:for="{{items}}"
      wx:key="_id"
      data-index="{{index}}"
      data-id="{{item._id}}">
      <text class="drag-handle" catchtouchstart="onDragStart" catchtouchmove="onDragMove" catchtouchend="onDragEnd" data-index="{{index}}">⋮⋮</text>
      <text class="item-content" catchtap="onItemTap" data-id="{{item._id}}">{{item.content}}</text>
      <view wx:if="{{item.status === 'pending'}}" class="pending-tag" catchtap="onPendingTagTap" data-id="{{item._id}}">
        待完成
      </view>
      <view wx:if="{{item.status === 'completed'}}" class="completed-tag" catchtap="onCompletedTagTap" data-id="{{item._id}}">
        已完成
      </view>
    </view>
    <view wx:if="{{items.length === 0}}" class="empty-state">
      今天还没有记录事项
    </view>
  </view>

  <!-- Pending items section (only in day view) -->
  <view class="pending-section" wx:if="{{viewMode === 'day' && pendingItems.length > 0}}">
    <view class="pending-section-header">
      <text class="pending-section-title">全部待办事项</text>
      <text class="pending-section-count">({{pendingItems.length}})</text>
    </view>
    <view class="pending-list">
      <view class="pending-item" wx:for="{{pendingItems}}" wx:key="_id" catchtap="onPendingItemClick" data-date="{{item.date}}">
        <text class="pending-item-content">{{item.content}}</text>
        <text class="pending-item-date">{{item.dateStr}}</text>
      </view>
    </view>
  </view>

  <!-- Week view -->
  <view class="week-view" wx:if="{{viewMode === 'week'}}">
    <view class="week-day" wx:for="{{weekDays}}" wx:key="date">
      <view class="week-day-header">
        <text class="week-day-name">{{item.dayName}}</text>
        <text class="week-day-date {{item.isToday ? 'today' : ''}}">{{item.dateStr}}</text>
      </view>
      <view class="week-day-items">
        <view class="week-item" wx:for="{{item.items}}" wx:for-item="dayItem" wx:key="_id">
          <text class="week-item-content" bindtap="onItemTap" data-id="{{dayItem._id}}">{{dayItem.content}}</text>
          <view wx:if="{{dayItem.status === 'pending'}}" class="pending-tag" bindtap="onPendingTagTap" data-id="{{dayItem._id}}">
            待完成
          </view>
        </view>
        <view wx:if="{{item.items.length === 0}}" class="empty-day">
          无事项
        </view>
      </view>
    </view>
  </view>

  <!-- Add button -->
  <view class="add-btn" bindtap="onAddItem">
    <text class="add-icon">+</text>
    <text class="add-text">添加事项</text>
  </view>
</view>

<!-- Complete confirmation modal -->
<view wx:if="{{showCompleteModal}}" class="modal-mask">
  <view class="modal-content">
    <view class="modal-title">此事项已完成了吗？</view>
    <view class="modal-actions">
      <view class="modal-btn reschedule" bindtap="onRescheduleClick">未完成，延期</view>
      <view class="modal-btn confirm" bindtap="onCompleteModalConfirm">已完成</view>
    </view>
  </view>
</view>

<!-- Reschedule modal -->
<view wx:if="{{showRescheduleModal}}" class="modal-mask">
  <view class="modal-content">
    <view class="modal-title">选择延期日期</view>
    <picker mode="date" value="{{rescheduleDate}}" end="{{maxDate}}" bindchange="onDateChange">
      <view class="picker-view">{{rescheduleDate || '请选择日期'}}</view>
    </picker>
    <view class="modal-actions">
      <view class="modal-btn cancel" bindtap="onRescheduleModalCancel">取消</view>
      <view class="modal-btn confirm" bindtap="onRescheduleModalConfirm">确定</view>
    </view>
  </view>
</view>

<!-- Delete confirmation modal -->
<view wx:if="{{showDeleteModal}}" class="modal-mask">
  <view class="modal-content">
    <view class="modal-title">确认删除？</view>
    <view class="modal-actions">
      <view class="modal-btn cancel" bindtap="onDeleteModalCancel">取消</view>
      <view class="modal-btn delete" bindtap="onDeleteModalConfirm">删除</view>
    </view>
  </view>
</view>

<!-- Mark as pending modal -->
<view wx:if="{{showPendingModal}}" class="modal-mask">
  <view class="modal-content">
    <view class="modal-title">标记为未完成？</view>
    <view class="modal-actions">
      <view class="modal-btn cancel" bindtap="onPendingModalCancel">取消</view>
      <view class="modal-btn confirm" bindtap="onPendingModalConfirm">确定</view>
    </view>
  </view>
</view>