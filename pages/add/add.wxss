.container {
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.form {
  flex: 1;
}

.input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.actions {
  display: flex;
  justify-content: space-between;
  padding-top: 40rpx;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.btn.cancel {
  background: #F5F5F5;
  color: #666;
}

.btn.confirm {
  background: #333;
  color: #fff;
}